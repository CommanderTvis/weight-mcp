# --- required ---------------------------------------------------------------
# The ADMIN account's password (username: "admin"). This is the only account
# configured here — the admin registers/deregisters further (non-admin) users
# from chat with the `register_user` / `deregister_user` / `update_user_password`
# tools; those accounts are stored in the database. Rotating this password
# invalidates every user's outstanding tokens.
WEIGHT_MCP_PASSWORD=change-me

# Public, externally reachable HTTPS base URL of this server. claude.ai connects
# from Anthropic's cloud, so this must be reachable from the public internet and
# match the URL you paste into the connector (without the /mcp path).
WEIGHT_MCP_PUBLIC_BASE_URL=https://weight.example.com

# --- network (optional) -----------------------------------------------------
WEIGHT_MCP_HOST=0.0.0.0
WEIGHT_MCP_PORT=8000

# --- storage (optional) -----------------------------------------------------
WEIGHT_MCP_DATABASE_PATH=data/weight.sqlite3

# Goals (calorie/protein targets, floor vs. ceiling) are not configured here —
# set them from chat with the `set_goals` tool; they persist in the database.

# --- locale (optional) ------------------------------------------------------
WEIGHT_MCP_REGION=DE
WEIGHT_MCP_LANGUAGE=de

# --- nutrition sources (optional) -------------------------------------------
# Open Food Facts: primary, no key, filtered to German products by default.
WEIGHT_MCP_OFF_ENABLED=true
WEIGHT_MCP_OFF_COUNTRY=germany
# USDA FoodData Central: optional secondary source, needs a free API key.
WEIGHT_MCP_USDA_ENABLED=false
WEIGHT_MCP_USDA_API_KEY=
